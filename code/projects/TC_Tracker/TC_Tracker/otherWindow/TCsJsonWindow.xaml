<Window x:Class="TC_Tracker.otherWindow.TCsJsonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker.otherWindow"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="路径信息" Height="300" Width="400">
    <Grid>
        <TextBox x:Name="jsonTextBox" HorizontalAlignment="Left" Height="214" Margin="10,10,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="374" IsReadOnly="True"/>
        <Button x:Name="copyButton" Content="拷贝" HorizontalAlignment="Left" Margin="163,241,0,0" VerticalAlignment="Top" Width="75" Click="copyButton_Click"/>
        <Label x:Name="label" Content="拷贝成功" HorizontalAlignment="Left" Margin="264,238,0,0" VerticalAlignment="Top" Visibility="Collapsed"/>
    </Grid>
</Window>
