<Page x:Class="TC_Tracker.otherWindow.VarSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker.otherWindow"
        mc:Ignorable="d"
        Title="VarSelector" Height="300" Width="500"
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="timeLabel" Content="时间变量" HorizontalAlignment="Center" Margin="0,49,0,0" VerticalAlignment="Top" Height="25" Width="58" />
        <Label x:Name="latLabel" Content="纬度变量" HorizontalAlignment="Left" Margin="65,88,0,0" VerticalAlignment="Top" Visibility="Collapsed" Height="0" Width="0"/>
        <Label x:Name="lonLabel" Content="经度变量" HorizontalAlignment="Left" Margin="65,133,0,0" VerticalAlignment="Top" Visibility="Collapsed" Height="0" Width="0"/>
        <Label x:Name="vorLabel" Content="涡度变量" HorizontalAlignment="Center" Margin="0,171,0,0" VerticalAlignment="Top" Height="25" Width="58"/>
        <ComboBox x:Name="comboBox_time" HorizontalAlignment="Center" Margin="0,53,0,0" VerticalAlignment="Top" Width="120" Visibility="Collapsed" Grid.Column="1" Height="0"/>
        <ComboBox x:Name="comboBox_lat" HorizontalAlignment="Left" Margin="82,90,0,0" VerticalAlignment="Top" Width="120" Visibility="Collapsed" Grid.Column="1" Height="0"/>
        <ComboBox x:Name="comboBox_lon" HorizontalAlignment="Left" Margin="82,133,0,0" VerticalAlignment="Top" Width="120" Visibility="Collapsed" Grid.Column="1" Height="0"/>
        <ComboBox x:Name="comboBox_vor" HorizontalAlignment="Left" Margin="82,175,0,0" VerticalAlignment="Top" Width="120" Grid.Column="1" Height="21"/>
        <Button x:Name="nextStepButton" Content="下一步" HorizontalAlignment="Center" Margin="0,244,0,0" VerticalAlignment="Top" Width="75" Click="nextStepButton_Click" Grid.Column="1" Height="19"/>
        <Button x:Name="button_OK" Content="确定" HorizontalAlignment="Left" Margin="231,244,0,0" VerticalAlignment="Top" Click="OKButton_Click" Width="55" IsEnabled="False" Grid.Column="1" Height="19"/>
        <Button x:Name="button_Cancel" Content="取消" HorizontalAlignment="Left" Margin="304,244,0,0" VerticalAlignment="Top" Width="50" Click="Cancelbutton_Click" Grid.Column="1" Height="19"/>
    </Grid>
</Page>
