<Window x:Class="TC_Tracker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="300" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid>
        <Label x:Name="label1" Content="中间文件存储文件夹" HorizontalAlignment="Left" Margin="37,24,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tempFDirTextBox" HorizontalAlignment="Left" Margin="44,54,0,0" Text="TextBox" TextWrapping="Wrap" VerticalAlignment="Top" Width="336" Height="19" KeyDown="DirTextBox_OnKeyDown" LostFocus="DirTextBox_OnLostFocus"/>
        <Button x:Name="okButton" Content="确定" HorizontalAlignment="Left" Margin="294,232,0,0" VerticalAlignment="Top" Height="26" Width="57" Click="OKbutton_Click"/>
        <Button x:Name="cancelButton" Content="取消" HorizontalAlignment="Left" Margin="380,232,0,0" VerticalAlignment="Top" Height="26" Width="55" Click="cancelButton_Click"/>
        <Button x:Name="button" Content="选择文件夹..." HorizontalAlignment="Left" Margin="408,54,0,0" VerticalAlignment="Top" Click="browsebutton_Click"/>

    </Grid>
</Window>
