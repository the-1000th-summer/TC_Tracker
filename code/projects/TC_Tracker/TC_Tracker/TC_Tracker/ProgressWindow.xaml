<Window x:Class="TC_Tracker.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        Title="ProgressWindow" Height="250" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Grid>
        <Button x:Name="cancelBtn" Content="取消" HorizontalAlignment="Left" Margin="398,190,0,0" VerticalAlignment="Top" Width="47"/>
        <Label x:Name="levelLabel" Content="Label" HorizontalAlignment="Left" Margin="324,37,0,0" VerticalAlignment="Top"/>
        <ProgressBar Name="progressBar" HorizontalAlignment="Center" Height="26" VerticalAlignment="Top" Width="390" Margin="0,125,0,0" IsIndeterminate="True"/>
        <ProgressBar Name="levelIndicator" HorizontalAlignment="Left" Height="10" Margin="127,49,0,0" VerticalAlignment="Top" Width="100"/>

    </Grid>
</Window>
