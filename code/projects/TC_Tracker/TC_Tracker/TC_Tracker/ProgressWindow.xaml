<Window x:Class="TC_Tracker.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        Title="ProgressWindow" Height="250" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Grid>
        <Button x:Name="button" Content="Button" HorizontalAlignment="Left" Margin="203,0,0,0" VerticalAlignment="Center"/>
        <Label x:Name="label" Content="Label" HorizontalAlignment="Left" Margin="266,104,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
