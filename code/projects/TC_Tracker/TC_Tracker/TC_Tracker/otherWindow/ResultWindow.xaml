<Window x:Class="TC_Tracker.otherWindow.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker.otherWindow"
        mc:Ignorable="d"
        Title="ResultWindow" Height="450" Width="800">
    <Grid Name="myGrid">
        <WebBrowser Name="webBrowser" HorizontalAlignment="Left" VerticalAlignment="Top" LoadCompleted="loadCompletedHandler" />
        <Popup Name="myPopup" IsOpen="True" Placement="Center"   AllowsTransparency="True" >
            <Button x:Name="button" Content="Button"/>
        </Popup>
        <Label x:Name="label" Content="Label" HorizontalAlignment="Left" Margin="666,328,0,0" VerticalAlignment="Top"/>




    </Grid>
</Window>
