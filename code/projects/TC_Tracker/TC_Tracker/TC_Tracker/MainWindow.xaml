<Window x:Class="TC_Tracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cm="clr-namespace:System.ComponentModel;assembly=System"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        x:Name="mainWin"
        Title="TC Tracker" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="windowClosing">
    <Window.Resources>
        <cm:BackgroundWorker x:Key="backgroundWorker" WorkerReportsProgress="True" WorkerSupportsCancellation="True" DoWork="bgWorker_DoWork" ProgressChanged="bgWorker_progressChanged" RunWorkerCompleted="bgWorker_runCompleted">
        </cm:BackgroundWorker>
    </Window.Resources>
    <Grid Background="Transparent" Drop="filePathDrop" AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu>
            <MenuItem Header="文件(_F)">
                <MenuItem x:Name="menu_selDir" Header="选择文件(_O)" Click="browseButton_Click" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}" />
                <MenuItem x:Name="menu_exportJson" Header="从step3文件导出json..." Click="menu_exportJson_Click" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}" />
                <MenuItem x:Name="menu_drawStep3" Header="导入step3文件以查看结果..." Click="menu_drawStep3_Click" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}" />
                <MenuItem Header="退出(_X)" Click="exit_OnClick" />
            </MenuItem>
            <MenuItem Header="偏好设置(_P)">
                <MenuItem x:Name="settings" Header="设置..." Click="settingsClicked" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}"></MenuItem>
                <MenuItem Header="关于..." Click="about_OnClick"></MenuItem>
            </MenuItem>
        </Menu>
        <Label x:Name="label" Content="工作文件" HorizontalAlignment="Left" Margin="28,26,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <TextBox x:Name="ncFileTextBox" HorizontalAlignment="Left" Margin="111,30,0,0" Grid.Row="1" Text="" TextWrapping="NoWrap" VerticalAlignment="Top" Width="507" Height="21" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}"/>
        <Button x:Name="button" Content="选择文件..." HorizontalAlignment="Left" Margin="660,28,0,0" Grid.Row="1" VerticalAlignment="Top" Height="25" Width="74" Click="browseButton_Click" IsEnabled="{Binding ElementName=mainWin, Path=isNotTracking}"/>
        <Button x:Name="selVarButton" Content="选择变量..." HorizontalAlignment="Left" Margin="129,83.333,0,0" Grid.Row="1" VerticalAlignment="Top" Height="27" Width="97" Click="varSelClicked" >
            <Button.IsEnabled>
                <MultiBinding Converter="{StaticResource booleanAndConverter}">
                    <Binding ElementName="mainWin" Path="selectedFile" />
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="isNotWrfoutFile" />
                </MultiBinding>
            </Button.IsEnabled>
        </Button>
        <Label x:Name="timeVarLabel" Content="时间变量名：" HorizontalAlignment="Left" Margin="112,137.333,0,0" Grid.Row="1" VerticalAlignment="Top" />
        <Label x:Name="label1" Content="纬度变量名：" HorizontalAlignment="Left" Margin="112,164.333,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <Label x:Name="label2" Content="经度变量名：" HorizontalAlignment="Left" Margin="112,194.333,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <Label x:Name="label3" Content="涡度变量名：" HorizontalAlignment="Left" Margin="112,224.333,0,0" Grid.Row="1" VerticalAlignment="Top" IsEnabled="{Binding ElementName=mainWin, Path=isNotWrfoutFile}" Visibility="{Binding ElementName=mainWin, Path=isNotWrfoutFile, Converter={StaticResource BoolToVis}}" />
        <TextBlock x:Name="timeNameTextBlock" HorizontalAlignment="Left" Margin="199,142.333,0,0" Grid.Row="1" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top" />
        <TextBlock x:Name="latNameTextBlock" HorizontalAlignment="Left" Margin="199,169.333,0,0" Grid.Row="1" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>
        <TextBlock x:Name="lonNameTextBlock" HorizontalAlignment="Left" Margin="199,199.333,0,0" Grid.Row="1" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top" />
        <TextBlock x:Name="vorNameTextBlock" HorizontalAlignment="Left" Margin="199,229.333,0,0" Grid.Row="1" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top" IsEnabled="{Binding ElementName=mainWin, Path=isNotWrfoutFile}" Visibility="{Binding ElementName=mainWin, Path=isNotWrfoutFile, Converter={StaticResource BoolToVis}}"/>

        <Label x:Name="label4" Content="z方向维度名：" HorizontalAlignment="Left" Margin="313,136.333,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <TextBlock x:Name="zLvNameTextBlock" HorizontalAlignment="Left" Margin="401,142.333,0,0" Grid.Row="1" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>
        <Label x:Name="label5" Content="选取第                    层数据" HorizontalAlignment="Left" Margin="313,161.333,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <Button x:Name="startTrackButton" Content="{Binding ElementName=mainWin, Path=isNotTracking, Converter={StaticResource StartTrackLabelConverter}}" HorizontalAlignment="Left" Margin="346,282,0,0" Grid.Row="1" VerticalAlignment="Top" Height="28" Width="89" Click="startTrackButton_Click">
            <Button.IsEnabled>
                <MultiBinding Converter="{StaticResource booleanAndConverter}">
                    <Binding ElementName="mainWin" Path="selectedFile" />
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="varNameSelected" />
                </MultiBinding>
            </Button.IsEnabled>
        </Button>
        <Button x:Name="stopButton" HorizontalAlignment="Left" Margin="610,282.333,0,0" Grid.Row="1" VerticalAlignment="Top" RenderTransformOrigin="-0.256,0.391" Height="28" Width="78" Click="stopButtonClicked" IsEnabled="{Binding ElementName=mainWin, Path=canStop}" >
            <Button.Content>
                <MultiBinding Converter="{StaticResource StopTrackLabelConverter}">
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="canStop" />
                </MultiBinding>
            </Button.Content>
        </Button>
        <Button x:Name="showWebButton" Content="查看结果..." HorizontalAlignment="Left" Margin="495,355,0,0" Grid.Row="1" VerticalAlignment="Top" Click="showWebButton_Click">
            <Button.IsEnabled>
                <MultiBinding Converter="{StaticResource booleanAndConverter}">
                    <Binding ElementName="mainWin" Path="selectedFile" />
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="trackFinished" />
                </MultiBinding>
            </Button.IsEnabled>
        </Button>
        <Button x:Name="exportButton" Content="导出全部结果..." HorizontalAlignment="Left" Margin="580,355,0,0" Grid.Row="1" VerticalAlignment="Top" Width="75" Click="exportButton_Click">
            <Button.IsEnabled>
                <MultiBinding Converter="{StaticResource booleanAndConverter}">
                    <Binding ElementName="mainWin" Path="selectedFile" />
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="trackFinished" />
                </MultiBinding>
            </Button.IsEnabled>
        </Button>
        <Button x:Name="step2Button" Content="startFromStep2" HorizontalAlignment="Left" Margin="81,325,0,0" Grid.Row="1" VerticalAlignment="Top" Height="40" Width="107" Click="step2Button_Click" IsEnabled="False" />
        <Button x:Name="step3Button" Content="startFromStep3" HorizontalAlignment="Left" Margin="215,328,0,0" Grid.Row="1" VerticalAlignment="Top" Height="34" Width="102" Click="step3Button_Click" IsEnabled="False" />
        <CheckBox x:Name="wrfoutCheckBox" Content="wrfout文件" HorizontalAlignment="Left" Margin="656,67,0,0" Grid.Row="1" VerticalAlignment="Top" IsEnabled="False" IsThreeState="False" IsChecked="{Binding ElementName=mainWin, Path=isNotWrfoutFile, Converter={StaticResource InverseBooleanConverter}}" />

        <ComboBox x:Name="zLvComboBox" HorizontalAlignment="Left" Margin="359,164.333,0,0" Grid.Row="1" VerticalAlignment="Top" Width="60" Height="20">
            <ComboBox.IsEnabled>
                <MultiBinding Converter="{StaticResource booleanAndConverter}">
                    <Binding ElementName="mainWin" Path="selectedFile" />
                    <Binding ElementName="mainWin" Path="isNotTracking" />
                    <Binding ElementName="mainWin" Path="varNameSelected" />
                    <Binding ElementName="mainWin" Path="zDimLvCanSelect" />
                </MultiBinding>
            </ComboBox.IsEnabled>
        </ComboBox>
        <Button x:Name="button1" Content="Button" HorizontalAlignment="Left" Margin="570,185.333,0,0" Grid.Row="1" VerticalAlignment="Top" Width="75" Click="button1_Click"/>


    </Grid>
</Window>
