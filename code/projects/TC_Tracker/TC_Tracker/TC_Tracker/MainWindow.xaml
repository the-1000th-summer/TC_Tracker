<Window x:Class="TC_Tracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label x:Name="label" Content="工作文件" HorizontalAlignment="Left" Margin="97,60,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="ncFileTextBox" HorizontalAlignment="Left" Margin="170,60,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="442" Height="25"/>
        <Button x:Name="button" Content="选择文件..." HorizontalAlignment="Left" Margin="644,60,0,0" VerticalAlignment="Top" Height="25" Width="78" Click="browseButton_Click"/>
        <Button x:Name="selVarButton" Content="选择变量..." HorizontalAlignment="Left" Margin="158,122,0,0" VerticalAlignment="Top" Height="34" Width="72"/>
        <Label x:Name="label1" Content="时间变量名：" HorizontalAlignment="Left" Margin="106,177,0,0" VerticalAlignment="Top"/>
        <Label x:Name="label1_Copy" Content="纬度变量名：" HorizontalAlignment="Left" Margin="106,207,0,0" VerticalAlignment="Top"/>
        <Label x:Name="label1_Copy1" Content="经度变量名：" HorizontalAlignment="Left" Margin="106,237,0,0" VerticalAlignment="Top"/>
        <Label x:Name="label1_Copy2" Content="涡度变量名：" HorizontalAlignment="Left" Margin="106,267,0,0" VerticalAlignment="Top"/>
        <TextBlock x:Name="timeNameTextBlock" HorizontalAlignment="Left" Margin="193,182,0,0" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>
        <TextBlock x:Name="latNameTextBlock" HorizontalAlignment="Left" Margin="193,212,0,0" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>
        <TextBlock x:Name="lonNameTextBlock" HorizontalAlignment="Left" Margin="193,242,0,0" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>
        <TextBlock x:Name="vorNameTextBlock" HorizontalAlignment="Left" Margin="193,272,0,0" TextWrapping="Wrap" Text="未指定" VerticalAlignment="Top"/>

    </Grid>
</Window>
