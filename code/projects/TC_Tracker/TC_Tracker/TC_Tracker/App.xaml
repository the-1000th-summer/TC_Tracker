<Application x:Class="TC_Tracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TC_Tracker"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:BooleanAndConverter x:Key="booleanAndConverter" />
        <local:BooleanOrConverter x:Key="booleanOrConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:PrevPageBtnConverter x:Key="PrevPageBtnConverter"/>
        <local:NextPageBtnConverter x:Key="NextPageBtnConverter"/>
        <local:StartTrackLabelConverter x:Key="StartTrackLabelConverter"/>
        <local:StopTrackLabelConverter x:Key="StopTrackLabelConverter"/>
    </Application.Resources>
</Application>
