<Window x:Class="TC_Tracker.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TC_Tracker"
        mc:Ignorable="d"
        Title="ResultWindow" Height="720" Width="1280">
    <Grid>

        <WebBrowser x:Name="webBrowser" Margin="0,0,135,0" LoadCompleted="loadCompletedHandler"/>
        <Button x:Name="button" Content="Button" HorizontalAlignment="Left" Margin="670,360,0,0" VerticalAlignment="Top" Click="button_Click"/>

    </Grid>
</Window>
